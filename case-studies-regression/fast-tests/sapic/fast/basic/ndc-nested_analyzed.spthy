lemma oneEventAlways:
  all-traces "((‚ąÉ #t. A( ) @ #t) ‚ą® (‚ąÉ #t. B( ) @ #t)) ‚ą® (‚ąÉ #t. C( ) @ #t)"
/*
guarded formula characterizing all counter-examples:
"(‚ąÄ #t. (A( ) @ #t) ‚áí ‚ä•) ‚ąß
 (‚ąÄ #t. (B( ) @ #t) ‚áí ‚ä•) ‚ąß
 (‚ąÄ #t. (C( ) @ #t) ‚áí ‚ä•)"
*/
simplify
solve( (‚ąÉ #t. (ProgressTo_11( ~prog_ ) @ #t))  ‚ą•
       (‚ąÉ #t. (ProgressTo_211( ~prog_ ) @ #t))  ‚ą•
       (‚ąÉ #t. (ProgressTo_221( ~prog_ ) @ #t)) )
  case case_1
  by contradiction /* from formulas */
next
  case case_2
  by contradiction /* from formulas */
next
  case case_3
  by contradiction /* from formulas */
qed

rule (modulo E) MessageIDRule[color=#ffffff, process="+", issapicrule,
                              role='Process']:
   [ Fr( ~mid_ ) ] --> [ MID_Receiver( ~mid_ ), MID_Sender( ~mid_ ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Init[color=#ffffff, process="+", issapicrule,
                     role='Process']:
   [ Fr( ~prog_ ) ]
  --[ ProgressFrom_( ~prog_ ), Init( ) ]->
   [ State_( ~prog_ ) ]

  /* has exactly the trivial AC variant */

