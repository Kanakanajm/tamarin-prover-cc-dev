lemma A_excludesBC:
  all-traces
  "(‚ąÉ #t. A( ) @ #t) ‚áí ((¬¨(‚ąÉ #t2. B( ) @ #t2)) ‚ąß (¬¨(‚ąÉ #t2. C( ) @ #t2)))"
/*
guarded formula characterizing all counter-examples:
"(‚ąÉ #t. (A( ) @ #t)) ‚ąß (((‚ąÉ #t2. (B( ) @ #t2)) ‚ą® (‚ąÉ #t2. (C( ) @ #t2))))"
*/
simplify
solve( (‚ąÉ #t2. (B( ) @ #t2))  ‚ą• (‚ąÉ #t2. (C( ) @ #t2)) )
  case case_1
  solve( State_( ~prog_ ) ‚Ė∂‚āÄ #t )
    case Init
    by solve( State_( ~prog_.1 ) ‚Ė∂‚āÄ #t2 )
  qed
next
  case case_2
  solve( State_( ~prog_ ) ‚Ė∂‚āÄ #t )
    case Init
    by solve( State_( ~prog_.1 ) ‚Ė∂‚āÄ #t2 )
  qed
qed

