theory NSLPK3XOR

begin

// Function signature and definition of the equational theory E

builtins: xor
functions: adec/2, aenc/2, fst/1, pair/2, pk/1, snd/1
equations:
    adec(aenc(x.1, pk(x.2)), x.2) = x.1,
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2









rule (modulo E) Register_pk:
   [ Fr( ~ltkA ) ]
  --[ Register( $A ) ]->
   [ !Ltk( $A, ~ltkA ), !Pk( $A, pk(~ltkA) ), Out( pk(~ltkA) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Reveal_ltk:
   [ !Ltk( A, ltkA ) ] --[ RevLtk( A ) ]-> [ Out( ltkA ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) I_1:
   [ Fr( ~ni ), !Pk( $R, pkR ) ]
  --[ OUT_I_1( aenc(<'1', ~ni, $I>, pkR) ) ]->
   [ Out( aenc(<'1', ~ni, $I>, pkR) ), St_I_1( $I, $R, ~ni ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) R_1:
   [
   !Ltk( $R, ltkR ), In( aenc(<'1', ni, I>, pk(ltkR)) ), !Pk( I, pkI ),
   Fr( ~nr )
   ]
  --[
  IN_R_1_ni( ni, aenc(<'1', ni, I>, pk(ltkR)) ),
  OUT_R_1( aenc(<'2', ni, ($RвҠ•~nr)>, pkI) ),
  Running( I, $R, <'init', ni, ~nr> )
  ]->
   [ Out( aenc(<'2', ni, ($RвҠ•~nr)>, pkI) ), St_R_1( $R, I, ni, ~nr ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) I_2:
   [
   St_I_1( I, R, ni ), !Ltk( I, ltkI ), In( aenc(<'2', ni, x>, pk(ltkI)) ),
   !Pk( R, pkR )
   ]
  --[
  IN_I_2_nr( (RвҠ•x), aenc(<'2', ni, x>, pk(ltkI)) ),
  Commit( I, R, <'init', ni, (RвҠ•x)> ), Running( R, I, <'resp', ni, (RвҠ•x)> )
  ]->
   [
   Out( aenc(<'3', (RвҠ•x)>, pkR) ), Secret( I, R, (RвҠ•x) ), Secret( I, R, ni )
   ]

  /*
  rule (modulo AC) I_2:
     [
     St_I_1( I, R, ni ), !Ltk( I, ltkI ), In( aenc(<'2', ni, x>, pk(ltkI)) ),
     !Pk( R, pkR )
     ]
    --[
    IN_I_2_nr( z, aenc(<'2', ni, x>, pk(ltkI)) ),
    Commit( I, R, <'init', ni, z> ), Running( R, I, <'resp', ni, z> )
    ]->
     [ Out( aenc(<'3', z>, pkR) ), Secret( I, R, z ), Secret( I, R, ni ) ]
    variants (modulo AC)
    1. R     = R.11
       x     = R.11
       z     = zero
    
    2. R     = R.11
       x     = zero
       z     = R.11
    
    3. R     = R.15
       x     = x.19
       z     = (R.15вҠ•x.19)
    
    4. R     = R.18
       x     = (R.18вҠ•z.25)
       z     = z.25
    
    5. R     = zero
       x     = x.11
       z     = x.11
    
    6. R     = (x.14вҠ•z.17)
       x     = x.14
       z     = z.17
    
    7. R     = (x.16вҠ•x.17)
       x     = (x.16вҠ•x.21)
       z     = (x.17вҠ•x.21)
  */

rule (modulo E) R_2:
   [
   St_R_1( R, I, ni, nr ), !Ltk( R, ltkR ), In( aenc(<'3', nr>, pk(ltkR)) )
   ]
  --[ Commit( R, I, <'resp', ni, nr> ) ]->
   [ Secret( R, I, nr ), Secret( R, I, ni ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Secrecy_claim:
   [ Secret( A, B, m ) ] --[ Secret( A, B, m ) ]-> [ ]

  /* has exactly the trivial AC variant */

lemma types [sources]:
  all-traces
  "(вҲҖ ni m1 #i.
     (IN_R_1_ni( ni, m1 ) @ #i) вҮ’
     ((вҲғ #j. (!KU( ni ) @ #j) вҲ§ (#j < #i)) вҲЁ (вҲғ #j. OUT_I_1( m1 ) @ #j))) вҲ§
   (вҲҖ nr m2 #i.
     (IN_I_2_nr( nr, m2 ) @ #i) вҮ’
     ((вҲғ #j. (!KU( nr ) @ #j) вҲ§ (#j < #i)) вҲЁ (вҲғ #j. OUT_R_1( m2 ) @ #j)))"
/*
guarded formula characterizing all counter-examples:
"((вҲғ ni m1 #i.
    (IN_R_1_ni( ni, m1 ) @ #i)
   вҲ§
    (вҲҖ #j. (!KU( ni ) @ #j) вҮ’ В¬(#j < #i)) вҲ§
    (вҲҖ #j. (OUT_I_1( m1 ) @ #j) вҮ’ вҠҘ)) вҲЁ
  (вҲғ nr m2 #i.
    (IN_I_2_nr( nr, m2 ) @ #i)
   вҲ§
    (вҲҖ #j. (!KU( nr ) @ #j) вҮ’ В¬(#j < #i)) вҲ§
    (вҲҖ #j. (OUT_R_1( m2 ) @ #j) вҮ’ вҠҘ)))"
*/
induction
  case non_empty_trace
  solve( (вҲғ ni m1 #i.
           (IN_R_1_ni( ni, m1 ) @ #i)
          вҲ§
           (вҲҖ #j. (!KU( ni ) @ #j) вҮ’ В¬(#j < #i)) вҲ§
           (вҲҖ #j. (OUT_I_1( m1 ) @ #j) вҮ’ вҠҘ))  вҲҘ
         (вҲғ nr m2 #i.
           (IN_I_2_nr( nr, m2 ) @ #i)
          вҲ§
           (вҲҖ #j. (!KU( nr ) @ #j) вҮ’ В¬(#j < #i)) вҲ§
           (вҲҖ #j. (OUT_R_1( m2 ) @ #j) вҮ’ вҠҘ)) )
    case case_2
    solve( (last(#i))  вҲҘ
           (вҲғ #j. (!KU( nr ) @ #j) вҲ§ (В¬(last(#j))) вҲ§ (#j < #i))  вҲҘ
           (вҲғ #j. (OUT_R_1( aenc(<'2', ni, x>, pk(ltkI)) ) @ #j) вҲ§ В¬(last(#j))) )
      case case_1
      solve( St_I_1( I, R, ni ) в–¶вӮҖ #i )
        case I_1
        solve( !Ltk( $I, ltkI ) в–¶вӮҒ #i )
          case Register_pk
          solve( !Pk( $R, pkR ) в–¶вӮғ #i )
            case Register_pk
            solve( !KU( aenc(<'2', ~ni, x>, pk(~ltkA)) ) @ #vk )
              case c_aenc
              solve( !KU( ~ni ) @ #vk.5 )
                case I_1
                solve( !KU( ~ltkA.1 ) @ #vk.7 )
                  case Reveal_ltk
                  solve( !KU( pk(~ltkA) ) @ #vk.5 )
                    case Register_pk
                    solve( splitEqs(0) )
                      case split_case_1
                      SOLVED // trace found
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

restriction onekeypername:
  "В¬(вҲғ A #i #j.
      ((Register( A ) @ #i) вҲ§ (Register( A ) @ #j)) вҲ§ (В¬(#i = #j)))"
  // safety formula

lemma nonce_secrecy:
  all-traces
  "В¬(вҲғ A B s #i.
      (((Secret( A, B, s ) @ #i) вҲ§ (вҲғ #j. K( s ) @ #j)) вҲ§
       (В¬(вҲғ #r. RevLtk( A ) @ #r))) вҲ§
      (В¬(вҲғ #r. RevLtk( B ) @ #r)))"
/*
guarded formula characterizing all counter-examples:
"вҲғ A B s #i.
  (Secret( A, B, s ) @ #i)
 вҲ§
  (вҲғ #j. (K( s ) @ #j)) вҲ§
  (вҲҖ #r. (RevLtk( A ) @ #r) вҮ’ вҠҘ) вҲ§
  (вҲҖ #r. (RevLtk( B ) @ #r) вҮ’ вҠҘ)"
*/
simplify
solve( Secret( A, B, s ) в–¶вӮҖ #i )
  case R_2_case_1
  solve( !KU( ~nr ) @ #vk )
    case I_2_case_1
    solve( !KU( ~ltkA.2 ) @ #vk.4 )
      case Reveal_ltk
      solve( !KU( aenc(<'3', ~nr>, pk(~ltkA)) ) @ #vk.2 )
        case c_aenc
        solve( !KU( aenc(<'1', ~ni, $A>, pk(~ltkA)) ) @ #vk.4 )
          case c_aenc
          solve( !KU( ~ni ) @ #vk.12 )
            case I_1
            solve( !KU( aenc(<'2', ~ni, ($RвҠ•~nr)>, pk(~ltkA.2)) ) @ #vk.6 )
              case R_1
              solve( !KU( ($RвҠ•$R.1) ) @ #vk.8 )
                case c_xor
                solve( !KU( pk(~ltkA) ) @ #vk.10 )
                  case Register_pk
                  SOLVED // trace found
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma injective_agree:
  all-traces
  "вҲҖ actor peer params #i.
    (Commit( actor, peer, params ) @ #i) вҮ’
    (((вҲғ #j.
        ((Running( actor, peer, params ) @ #j) вҲ§ (#j < #i)) вҲ§
        (В¬(вҲғ actor2 peer2 #i2.
            (Commit( actor2, peer2, params ) @ #i2) вҲ§ (В¬(#i = #i2))))) вҲЁ
      (вҲғ #r. RevLtk( actor ) @ #r)) вҲЁ
     (вҲғ #r. RevLtk( peer ) @ #r))"
/*
guarded formula characterizing all counter-examples:
"вҲғ actor peer params #i.
  (Commit( actor, peer, params ) @ #i)
 вҲ§
  (вҲҖ #j.
    (Running( actor, peer, params ) @ #j)
   вҮ’
    ((В¬(#j < #i)) вҲЁ
     (вҲғ actor2 peer2 #i2.
       (Commit( actor2, peer2, params ) @ #i2) вҲ§ В¬(#i = #i2)))) вҲ§
  (вҲҖ #r. (RevLtk( actor ) @ #r) вҮ’ вҠҘ) вҲ§
  (вҲҖ #r. (RevLtk( peer ) @ #r) вҮ’ вҠҘ)"
*/
simplify
solve( Commit( actor, peer, params ) @ #i )
  case R_2
  solve( St_R_1( actor, peer, ni, nr ) в–¶вӮҖ #i )
    case R_1
    solve( !Ltk( $R, ltkR ) в–¶вӮҒ #i )
      case Register_pk
      solve( !KU( aenc(<'3', ~nr>, pk(~ltkA)) ) @ #vk )
        case c_aenc
        solve( !KU( ~nr ) @ #vk.5 )
          case I_2_case_1
          solve( !KU( ~ltkA.2 ) @ #vk.7 )
            case Reveal_ltk
            solve( !KU( aenc(<'1', ~ni, $A>, pk(~ltkA)) ) @ #vk.4 )
              case c_aenc
              solve( !KU( ~ni ) @ #vk.12 )
                case I_1
                solve( !KU( pk(~ltkA) ) @ #vk.6 )
                  case Register_pk
                  solve( !KU( aenc(<'2', ~ni, ($RвҠ•~nr)>, pk(~ltkA.2)) ) @ #vk.9 )
                    case R_1
                    solve( !KU( ($RвҠ•$R.1) ) @ #vk.11 )
                      case c_xor
                      SOLVED // trace found
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma session_key_setup_possible:
  exists-trace
  "вҲғ A B s #i.
    ((Secret( A, B, s ) @ #i) вҲ§ (В¬(вҲғ #r. RevLtk( A ) @ #r))) вҲ§
    (В¬(вҲғ #r. RevLtk( B ) @ #r))"
/*
guarded formula characterizing all satisfying traces:
"вҲғ A B s #i.
  (Secret( A, B, s ) @ #i)
 вҲ§
  (вҲҖ #r. (RevLtk( A ) @ #r) вҮ’ вҠҘ) вҲ§ (вҲҖ #r. (RevLtk( B ) @ #r) вҮ’ вҠҘ)"
*/
simplify
solve( Secret( A, B, s ) в–¶вӮҖ #i )
  case I_2_case_1
  solve( !KU( aenc(<'2', ~ni, x>, pk(~ltkA)) ) @ #vk )
    case R_1
    solve( splitEqs(1) )
      case split_case_1
      solve( !KU( aenc(<'1', ~ni, $I>, pk(~ltkA.1)) ) @ #vk.1 )
        case I_1
        SOLVED // trace found
      qed
    qed
  qed
qed













