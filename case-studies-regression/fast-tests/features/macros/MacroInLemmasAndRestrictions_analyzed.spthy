theory MacrosInLemmasAndRestrictions

begin

// Function signature and definition of the equational theory E

functions: fst/1, pair/2, snd/1
equations: fst(<x.1, x.2>) = x.1, snd(<x.1, x.2>) = x.2





macros: m( x ) =  x,
        m2( x, y ) =  <x, y>,
        m3( x ) =  x

rule (modulo E) A:
   [ In( x ) ] --[ A( m(x) ) ]-> [ ]

  /*
  rule (modulo AC) A:
     [ In( x ) ] --[ A( x ) ]-> [ ]
  */

rule (modulo E) B:
   [ In( x ), In( y ) ] --[ B( m2(x, y) ) ]-> [ ]

  /*
  rule (modulo AC) B:
     [ In( x ), In( y ) ] --[ B( <x, y> ) ]-> [ ]
  */

rule (modulo E) C:
   [ In( x ) ] --[ C( x ) ]-> [ ]

  /* has exactly the trivial AC variant */

restriction OnlyValidProcessing:
  "∀ x #i. (A( m(m3(x)) ) @ #i) ⇒ (∃ y. x = y)"

  /*
  expanded formula:
  "∀ x #i. (A( x ) @ #i) ⇒ (∃ y. x = y)"
  */

lemma M:
  exists-trace "∃ x #i. A( m(x) ) @ #i"
/*
guarded formula characterizing all satisfying traces:
"∃ x #i. (A( x ) @ #i)"
*/
simplify
SOLVED // trace found







/* All wellformedness checks were successful. */

