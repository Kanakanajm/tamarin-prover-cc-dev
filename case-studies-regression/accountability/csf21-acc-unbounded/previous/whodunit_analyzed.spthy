  */

rule (modulo E) p_0_1111111211[color=#6c8040, process='|', issapicrule,
                               role='P']:
   [ State_1111111211( $x.1, $y.1, c_AJ.1, c_SA.1, c_SJ.1, sid.1 ) ]
  -->
