lemma acc_blamed_min:
  all-traces
  "∀ x sid #i.
    (Blame( sid, x ) @ #i) ⇒
    (¬(∃ x.1 sid.1 #i.1.
        (Blame( sid.1, x.1 ) @ #i.1) ∧ ((x.1 = x) ∧ (¬(x = x.1)))))"
