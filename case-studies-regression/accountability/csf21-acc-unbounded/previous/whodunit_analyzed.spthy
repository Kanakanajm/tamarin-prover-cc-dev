theory WhoDunit

begin

// Function signature and definition of the equational theory E

functions: extract/1, fst/1, pair/2, pk/1, sig/2,
           sk/1[private,constructor], snd/1, true/0, verify/3
equations:
    extract(sig(m, sk(i))) = m,
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2,
    verify(sig(m, sk(i)), m, pk(sk(i))) = true



heuristic: p













restriction unequal_blame:
  "∀ sid #i. (Unequal( sid ) @ #i) ⇒ (∃ x #j. Blame( sid, x ) @ #j)"























rule (modulo E) Init[color=#ffffff, process='!', issapicrule,
                     role='Process']:
   [ ] --[ Init( ) ]-> [ State_( ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) p_0_[color=#ffffff, process='!', issapicrule,
                     role='Process']:
   [ State_( ) ] --> [ !Semistate_1( ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) p_1_[color=#ffffff, process='!', issapicrule,
                     role='Process']:
   [ !Semistate_1( ) ] --> [ State_1( ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) P_0_1[color=#ffffff, process='P()', issapicrule,
                      role='Process']:
   [ State_1( ) ] --> [ State_11( ), State_12( ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) newsid_0_11[color=#6c8040, process='new sid.1;',
                            issapicrule, role='P']:
   [ State_11( ), Fr( sid.1 ) ] --> [ State_111( sid.1 ) ]

  /*
  rule (modulo AC) newsid_0_11[color=#6c8040, process='new sid.1;',
                               issapicrule, role='P']:
     [ State_11( ), Fr( sid ) ] --> [ State_111( sid ) ]
  */

rule (modulo E) newcSA_0_111[color=#6c8040, process='new c_SA.1;',
                             issapicrule, role='P']:
   [ State_111( sid.1 ), Fr( c_SA.1 ) ] --> [ State_1111( c_SA.1, sid.1 ) ]

  /*
  rule (modulo AC) newcSA_0_111[color=#6c8040, process='new c_SA.1;',
                                issapicrule, role='P']:
     [ State_111( sid ), Fr( c_SA ) ] --> [ State_1111( c_SA, sid ) ]
  */

rule (modulo E) newcAJ_0_1111[color=#6c8040, process='new c_AJ.1;',
                              issapicrule, role='P']:
   [ State_1111( c_SA.1, sid.1 ), Fr( c_AJ.1 ) ]
  -->
   [ State_11111( c_AJ.1, c_SA.1, sid.1 ) ]

  /*
  rule (modulo AC) newcAJ_0_1111[color=#6c8040, process='new c_AJ.1;',
                                 issapicrule, role='P']:
     [ State_1111( c_SA, sid ), Fr( c_AJ ) ]
    -->
     [ State_11111( c_AJ, c_SA, sid ) ]
  */

rule (modulo E) newcSJ_0_11111[color=#6c8040, process='new c_SJ.1;',
                               issapicrule, role='P']:
   [ State_11111( c_AJ.1, c_SA.1, sid.1 ), Fr( c_SJ.1 ) ]
  -->
   [ State_111111( c_AJ.1, c_SA.1, c_SJ.1, sid.1 ) ]

  /*
  rule (modulo AC) newcSJ_0_11111[color=#6c8040, process='new c_SJ.1;',
                                  issapicrule, role='P']:
     [ State_11111( c_AJ, c_SA, sid ), Fr( c_SJ ) ]
    -->
     [ State_111111( c_AJ, c_SA, c_SJ, sid ) ]
  */

rule (modulo E) inxy_0_111111[color=#6c8040, process='in(<$x.1, $y.1>);',
                              issapicrule, role='P']:
   [ State_111111( c_AJ.1, c_SA.1, c_SJ.1, sid.1 ), In( <$x.1, $y.1> ) ]
  -->
   [ State_1111111( $x.1, $y.1, c_AJ.1, c_SA.1, c_SJ.1, sid.1 ) ]

  /*
  rule (modulo AC) inxy_0_111111[color=#6c8040,
                                 process='in(<$x.1, $y.1>);', issapicrule, role='P']:
     [ State_111111( c_AJ, c_SA, c_SJ, sid ), In( <$x, $y> ) ]
    -->
     [ State_1111111( $x, $y, c_AJ, c_SA, c_SJ, sid ) ]
  */

rule (modulo E) ifxy_0_1111111[color=#6c8040, process='if $x.1=$y.1',
                               issapicrule, role='P']:
   [ State_1111111( $x.1, $y.1, c_AJ.1, c_SA.1, c_SJ.1, sid.1 ) ]
  --[ Pred_Eq( $x.1, $y.1 ) ]->
   [ State_11111111( $x.1, $y.1, c_AJ.1, c_SA.1, c_SJ.1, sid.1 ) ]

  /*
  rule (modulo AC) ifxy_0_1111111[color=#6c8040, process='if $x.1=$y.1',
                                  issapicrule, role='P']:
     [ State_1111111( $x, $y, c_AJ, c_SA, c_SJ, sid ) ]
    --[ Pred_Eq( $x, $y ) ]->
     [ State_11111111( $x, $y, c_AJ, c_SA, c_SJ, sid ) ]
  */

rule (modulo E) ifxy_1_1111111[color=#6c8040, process='if $x.1=$y.1',
                               issapicrule, role='P']:
   [ State_1111111( $x.1, $y.1, c_AJ.1, c_SA.1, c_SJ.1, sid.1 ) ]
  --[ Pred_Not_Eq( $x.1, $y.1 ) ]->
   [ State_11111112( $x.1, $y.1, c_AJ.1, c_SA.1, c_SJ.1, sid.1 ) ]

  /*
  rule (modulo AC) ifxy_1_1111111[color=#6c8040, process='if $x.1=$y.1',
                                  issapicrule, role='P']:
     [ State_1111111( $x, $y, c_AJ, c_SA, c_SJ, sid ) ]
    --[ Pred_Not_Eq( $x, $y ) ]->
     [ State_11111112( $x, $y, c_AJ, c_SA, c_SJ, sid ) ]
  */

rule (modulo E) p_0_11111111[color=#6c8040, process='0', issapicrule,
