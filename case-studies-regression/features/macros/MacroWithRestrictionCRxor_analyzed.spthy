          qed
        qed
      qed
    next
      case split_case_7
      solve( !KU( h((~kвКХx)) ) @ #vk.1 )
        case c_h
        solve( !KU( (~naвКХx) ) @ #vk.2 )
          case c_xor
          solve( !KU( (~kвКХx) ) @ #vk.3 )
            case c_xor
            by solve( !KU( ~k ) @ #vk.6 )
          next
            case coerce
            solve( !KD( (~kвКХx) ) вЦґвВА #vk.2 )
              case initiator
