            qed
          qed
        qed
      next
        case coerce
        solve( !KD( (~kвКХ~naвКХz) ) вЦґвВА #vk )
          case initiator
          by contradiction /* impossible chain */
        next
          case responder
          solve( (#vl, 0) ~~> (#vk, 0) )
