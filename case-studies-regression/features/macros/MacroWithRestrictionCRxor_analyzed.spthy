qed

lemma recentalive_tag:
  all-traces
  "вИА x y #i.
    (Alive( x, y ) @ #i) вЗТ
    (вИГ #j #k.
      (((Challenge( x ) @ #k) вИІ (Response( y ) @ #j)) вИІ (#k < #j)) вИІ
      (#j < #i))"
/*
guarded formula characterizing all counter-examples:
"вИГ x y #i.
  (Alive( x, y ) @ #i)
 вИІ
  вИА #j #k.
   (Challenge( x ) @ #k) вИІ (Response( y ) @ #j)
  вЗТ
   ((¬ђ(#k < #j)) вИ® (¬ђ(#j < #i)))"
*/
simplify
solve( Initiated( ~na ) вЦґвВА #i )
  case initiator
  solve( !InitLTK( ~k ) вЦґвВБ #i )
    case Setup
    solve( splitEqs(0) )
      case split_case_7
      solve( !KU( h((~kвКХx)) ) @ #vk.1 )
        case responder
        solve( splitEqs(2) )
          case split_case_2
          solve( !KU( (~naвКХ~nbвКХna.1) ) @ #vk.2 )
            case c_xor_case_1
            solve( !KU( (~naвКХna.1) ) @ #vk.4 )
              case c_xor
              solve( !KU( ~nb ) @ #vk.5 )
                case responder
                solve( !KU( ~na ) @ #vk.6 )
                  case initiator
                  SOLVED // trace found
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma executable:
  exists-trace
  "вИГ x y #i #j.
    (((Alive( x, y ) @ #i) вИІ (Response( y ) @ #j)) вИІ
     (¬ђ(вИГ #k. (Response( y ) @ #k) вИІ (¬ђ(#j = #k))))) вИІ
    (¬ђ(вИГ #l. NeqForExec( x, x ) @ #l))"
/*
guarded formula characterizing all satisfying traces:
"вИГ x y #i #j.
  (Alive( x, y ) @ #i) вИІ (Response( y ) @ #j)
 вИІ
  (вИА #k. (Response( y ) @ #k) вЗТ #j = #k) вИІ
  (вИА #l. (NeqForExec( x, x ) @ #l) вЗТ вК•)"
*/
simplify
solve( Initiated( ~na ) вЦґвВА #i )
  case initiator
  solve( !InitLTK( ~k ) вЦґвВБ #i )
    case Setup
    solve( !RespLTK( ~k ) вЦґвВВ #j )
      case Setup
      solve( splitEqs(0) )
        case split_case_3
        solve( !KU( h((~kвКХ~naвКХnb)) ) @ #vk.1 )
          case responder
          solve( splitEqs(1) )
            case split_case_1
            solve( !KU( ~nb ) @ #vk.2 )
              case responder
              solve( !KU( ~na ) @ #vk.3 )
                case initiator
                SOLVED // trace found
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed









