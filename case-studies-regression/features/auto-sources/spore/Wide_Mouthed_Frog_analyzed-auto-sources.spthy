    (((Ôłâ #j.
        ((Running_A( A, B, t ) @ #j) Ôłž (#j < #i)) Ôłž
        (┬Č(Ôłâ A2 B2 #i2. (Commit_B( A2, B2, t ) @ #i2) Ôłž (┬Č(#i2 = #i))))) ÔłĘ
