        solve( !Ltk( ~kbs.1, $B.1 ) ÔûÂÔéü #i2 )
          case Init
          solve( !KU( senc(<'2', ts.1, A2, ~kab>, ~kbs.1) ) @ #vk.4 )
            case S_to_B
            solve( !KU( senc(<'1', ta.1, $B.1, ~kab>, ~kas.1) ) @ #vk.7 )
