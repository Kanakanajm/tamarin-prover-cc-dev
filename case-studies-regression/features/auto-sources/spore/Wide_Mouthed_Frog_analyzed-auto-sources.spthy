lemma AUTO_typing [sources]:
  all-traces
  "(Ôèñ) Ôêº
   (ÔêÇ x m #i.
     (AUTO_IN_TERM_0_0_1_0_1_1_1__S_to_B( m, x ) @ #i) ÔçÆ
     ((Ôêâ #j. (!KU( x ) @ #j) Ôêº (#j < #i)) Ôê¿
      (Ôêâ #j. (AUTO_OUT_TERM_0_0_1_0_1_1_1__S_to_B( m ) @ #j) Ôêº (#j < #i))))"
/*
guarded formula characterizing all counter-examples:
"Ôêâ x m #i.
  (AUTO_IN_TERM_0_0_1_0_1_1_1__S_to_B( m, x ) @ #i)
 Ôêº
  (ÔêÇ #j. (!KU( x ) @ #j) ÔçÆ ┬¼(#j < #i)) Ôêº
  (ÔêÇ #j. (AUTO_OUT_TERM_0_0_1_0_1_1_1__S_to_B( m ) @ #j) ÔçÆ ┬¼(#j < #i))"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i))  ÔêÑ
         (Ôêâ #j. (!KU( x ) @ #j) Ôêº (┬¼(last(#j))) Ôêº (#j < #i))  ÔêÑ
         (Ôêâ #j.
           (AUTO_OUT_TERM_0_0_1_0_1_1_1__S_to_B( senc(<'1', ta, b, x>, ~kas) ) @ #j)
          Ôêº
