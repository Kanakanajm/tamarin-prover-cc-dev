    (Commit_B( A, B, t ) @ #i) ÔçÆ
    (((Ôêâ #j.
        ((Running_A( A, B, t ) @ #j) Ôêº (#j < #i)) Ôêº
        (┬¼(Ôêâ A2 B2 #i2. (Commit_B( A2, B2, t ) @ #i2) Ôêº (┬¼(#i2 = #i))))) Ôê¿
