theory LAK06

begin

// Function signature and definition of the equational theory E

builtins: xor
functions: fst/1, h/1, pair/2, snd/1
equations: fst(<x.1, x.2>) = x.1, snd(<x.1, x.2>) = x.2









rule (modulo E) setup:
   [ Fr( ~k ) ]
  --[ OnlyOnce( 'setup' ), Create( ~k ) ]->
   [ !Reader( ~k ), !Tag( ~k ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) initiatereader:
   [ !Reader( ~k ), Fr( ~r0 ) ]
  --[ OnlyOnce( 'initiareader' ) ]->
   [ ReaderState1( ~k, ~r0 ), Out( ~r0 ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) tag1:
   [ !Tag( ~k ), Fr( ~r1 ), In( r0 ) ]
  --[ Running( <'R', 'T', ~k, r0, ~r1> ) ]->
   [ TagState1( ~k, ~r1, r0 ), Out( <~r1, h((~kâŠ•~r1âŠ•r0))> ) ]

  /*
  rule (modulo AC) tag1:
     [ !Tag( ~k ), Fr( ~r1 ), In( r0 ) ]
    --[ Running( <'R', 'T', ~k, r0, ~r1> ) ]->
     [ TagState1( ~k, ~r1, r0 ), Out( <~r1, h(z)> ) ]
    variants (modulo AC)
    1. ~k    = ~k.7
       ~r1   = ~r1.8
       r0    = ~k.7
       z     = ~r1.8
    
    2. ~k    = ~k.7
       ~r1   = ~r1.8
       r0    = zero
       z     = (~k.7âŠ•~r1.8)
    
    3. ~k    = ~k.8
       ~r1   = ~r1.9
       r0    = r0.10
       z     = (~k.8âŠ•~r1.9âŠ•r0.10)
    
    4. ~k    = ~k.14
       ~r1   = ~r1.15
       r0    = (~k.14âŠ•x.26)
       z     = (~r1.15âŠ•x.26)
  */

rule (modulo E) acceptreader:
   [ ReaderState1( ~k, ~r0 ), In( <r1, h((~kâŠ•~r0âŠ•r1))> ) ]
  --[ Commit( <'R', 'T', ~k, ~r0, r1> ), Running( <'T', 'R', ~k, ~r0, r1> )
  ]->
   [ Out( h((~kâŠ•~r0âŠ•h((~kâŠ•~r0âŠ•r1)))) ) ]

  /*
  rule (modulo AC) acceptreader:
     [ ReaderState1( ~k, ~r0 ), In( <r1, h(z)> ) ]
    --[ Commit( <'R', 'T', ~k, ~r0, r1> ), Running( <'T', 'R', ~k, ~r0, r1> )
    ]->
     [ Out( h(z.1) ) ]
    variants (modulo AC)
    1. ~k    = ~k.8
       ~r0   = ~r0.9
       r1    = ~k.8
       z     = ~r0.9
       z.1   = (~k.8âŠ•~r0.9âŠ•h(~r0.9))
    
    2. ~k    = ~k.8
       ~r0   = ~r0.9
       r1    = ~r0.9
       z     = ~k.8
       z.1   = (~k.8âŠ•~r0.9âŠ•h(~k.8))
    
    3. ~k    = ~k.8
       ~r0   = ~r0.9
       r1    = zero
       z     = (~k.8âŠ•~r0.9)
       z.1   = (~k.8âŠ•~r0.9âŠ•h((~k.8âŠ•~r0.9)))
    
    4. ~k    = ~k.8
       ~r0   = ~r0.9
       r1    = (~k.8âŠ•~r0.9)
       z     = zero
       z.1   = (~k.8âŠ•~r0.9âŠ•h(zero))
    
    5. ~k    = ~k.9
       ~r0   = ~k.9
       r1    = r1.11
       z     = r1.11
       z.1   = h(r1.11)
    
    6. ~k    = ~k.9
       ~r0   = ~r0.10
       r1    = r1.11
       z     = (~k.9âŠ•~r0.10âŠ•r1.11)
       z.1   = (~k.9âŠ•~r0.10âŠ•h((~k.9âŠ•~r0.10âŠ•r1.11)))
    
    7. ~k    = ~k.10
       ~r0   = ~r0.11
       r1    = (~k.10âŠ•~r0.11âŠ•z.13)
       z     = z.13
       z.1   = (~k.10âŠ•~r0.11âŠ•h(z.13))
    
    8. ~k    = ~k.15
       ~r0   = ~r0.16
       r1    = (~r0.16âŠ•x.28)
       z     = (~k.15âŠ•x.28)
       z.1   = (~k.15âŠ•~r0.16âŠ•h((~k.15âŠ•x.28)))
    
    9. ~k    = ~k.16
       ~r0   = ~r0.17
       r1    = (~k.16âŠ•x.30)
       z     = (~r0.17âŠ•x.30)
       z.1   = (~k.16âŠ•~r0.17âŠ•h((~r0.17âŠ•x.30)))
  */

rule (modulo E) accepttag:
   [ TagState1( ~k, ~r1, r0 ), In( h((~kâŠ•r0âŠ•h((~kâŠ•~r1âŠ•r0)))) ) ]
  --[ Commit( <'T', 'R', ~k, r0, ~r1> ), FinTag( ) ]->
   [ ]

  /*
  rule (modulo AC) accepttag:
     [ TagState1( ~k, ~r1, r0 ), In( h(z) ) ]
    --[ Commit( <'T', 'R', ~k, r0, ~r1> ), FinTag( ) ]->
     [ ]
    variants (modulo AC)
     1. ~k    = ~k.6
        ~r1   = ~k.6
        r0    = zero
        z     = (~k.6âŠ•h(zero))
    
     2. ~k    = ~k.7
        ~r1   = ~r1.8
        r0    = ~k.7
        z     = h(~r1.8)
    
     3. ~k    = ~k.7
        ~r1   = ~r1.8
        r0    = ~r1.8
        z     = (~k.7âŠ•~r1.8âŠ•h(~k.7))
    
     4. ~k    = ~k.7
        ~r1   = ~r1.8
        r0    = zero
        z     = (~k.7âŠ•h((~k.7âŠ•~r1.8)))
    
     5. ~k    = ~k.7
        ~r1   = ~r1.8
        r0    = (~k.7âŠ•~r1.8)
        z     = (~r1.8âŠ•h(zero))
    
     6. ~k    = ~k.8
        ~r1   = ~k.8
        r0    = r0.10
        z     = (~k.8âŠ•r0.10âŠ•h(r0.10))
    
     7. ~k    = ~k.8
        ~r1   = ~r1.9
        r0    = r0.10
        z     = (~k.8âŠ•r0.10âŠ•h((~k.8âŠ•~r1.9âŠ•r0.10)))
    
     8. ~k    = ~k.13
        ~r1   = ~r1.14
        r0    = (~r1.14âŠ•x.24)
        z     = (~k.13âŠ•~r1.14âŠ•x.24âŠ•h((~k.13âŠ•x.24)))
    
     9. ~k    = ~k.14
        ~r1   = ~r1.15
        r0    = (~k.14âŠ•~r1.15âŠ•x.26)
        z     = (~r1.15âŠ•x.26âŠ•h(x.26))
    
    10. ~k    = ~k.14
        ~r1   = ~r1.15
        r0    = (~k.14âŠ•x.26)
        z     = (x.26âŠ•h((~r1.15âŠ•x.26)))
  */

lemma executable:
  exists-trace
  "(âˆƒ #i. FinTag( ) @ #i) âˆ§
   (âˆ€ x #i1 #i2.
     ((OnlyOnce( x ) @ #i1) âˆ§ (OnlyOnce( x ) @ #i2)) â‡’ (#i1 = #i2))"
/*
guarded formula characterizing all satisfying traces:
"(âˆƒ #i. (FinTag( ) @ #i)) âˆ§
 (âˆ€ x #i1 #i2. (OnlyOnce( x ) @ #i1) âˆ§ (OnlyOnce( x ) @ #i2) â‡’ #i1 = #i2)"
*/
simplify
solve( TagState1( ~k, ~r1, r0 ) â–¶â‚€ #i )
  case tag1
  solve( splitEqs(0) )
    case split_case_3
    solve( !KU( h((~kâŠ•r0âŠ•h((~kâŠ•~r1âŠ•r0)))) ) @ #vk )
      case acceptreader
      solve( !KU( ~r1 ) @ #vk.3 )
        case tag1
        solve( !KU( ~r0 ) @ #vk.2 )
          case initiatereader
          solve( !KU( h((~kâŠ•~r0âŠ•~r1)) ) @ #vk.4 )
            case tag1
            solve( splitEqs(5) )
              case split
              SOLVED // trace found
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma helpingSecrecy [reuse]:
  all-traces "âˆ€ k #i. (Create( k ) @ #i) â‡’ (Â¬(âˆƒ #j. K( k ) @ #j))"
/*
guarded formula characterizing all counter-examples:
"âˆƒ k #i. (Create( k ) @ #i) âˆ§ âˆƒ #j. (K( k ) @ #j)"
*/
simplify
by solve( !KU( ~k ) @ #vk )

lemma noninjectiveagreementTAG [use_induction]:
  all-traces
  "âˆ€ t #i.
    (Commit( <'T', 'R', t> ) @ #i) â‡’ (âˆƒ #j. Running( <'T', 'R', t> ) @ #j)"
/*
guarded formula characterizing all counter-examples:
"âˆƒ t #i.
  (Commit( <'T', 'R', t> ) @ #i)
 âˆ§
  âˆ€ #j. (Running( <'T', 'R', t> ) @ #j) â‡’ âŠ¥"
*/
induction
  case empty_trace
  by contradiction /* from formulas */
next
  case non_empty_trace
  solve( (last(#i))  âˆ¥
         (âˆƒ #j. (Running( <'T', 'R', t> ) @ #j) âˆ§ Â¬(last(#j))) )
    case case_1
    solve( Commit( <'T', 'R', t> ) @ #i )
      case accepttag
      solve( TagState1( ~k, ~r1, r0 ) â–¶â‚€ #i )
        case tag1
        solve( splitEqs(0) )
          case split_case_1
          by contradiction /* from formulas */
        next
          case split_case_2
          solve( !KU( h((~kâŠ•h((~kâŠ•~r1)))) ) @ #vk )
            case c_h
            solve( !KU( (~kâŠ•h((~kâŠ•~r1))) ) @ #vk.2 )
              case c_xor
              by solve( !KU( ~k ) @ #vk.4 )
            next
              case coerce
              solve( !KD( (~kâŠ•h((~kâŠ•~r1))) ) â–¶â‚€ #vk.1 )
                case acceptreader
                by solve( (#vl, 0) ~~> (#vk.1, 0) )
              next
                case initiatereader
                by contradiction /* impossible chain */
              next
                case tag1
                solve( (#vl, 0) ~~> (#vk.1, 0) )
                  case d_0_fst
                  by contradiction /* impossible chain */
                next
                  case d_0_snd
                  by solve( (#vr.3, 0) ~~> (#vk.1, 0) )
                qed
              qed
            qed
          qed
        next
          case split_case_3
          solve( !KU( h((~kâŠ•r0âŠ•h((~kâŠ•~r1âŠ•r0)))) ) @ #vk )
            case acceptreader
            solve( !KU( ~r0 ) @ #vk.1 )
              case fresh
              by solve( splitEqs(3) )
            next
              case initiatereader
              solve( splitEqs(3) )
                case split
                by contradiction /* from formulas */
              qed
            next
              case tag1
              by solve( splitEqs(3) )
            qed
          next
            case c_h
            solve( !KU( (~kâŠ•r0âŠ•h((~kâŠ•~r1âŠ•r0))) ) @ #vk.2 )
              case c_xor_case_1
              solve( !KU( (~kâŠ•h((~kâŠ•~r1âŠ•r0))) ) @ #vk.3 )
                case c_xor
                by solve( !KU( ~k ) @ #vk.5 )
              next
                case coerce
                solve( !KD( (~kâŠ•h((~kâŠ•~r1âŠ•r0))) ) â–¶â‚€ #vk.2 )
                  case acceptreader
                  by solve( (#vl, 0) ~~> (#vk.2, 0) )
                next
                  case initiatereader
                  by contradiction /* impossible chain */
                next
                  case tag1
                  solve( (#vl, 0) ~~> (#vk.2, 0) )
                    case d_0_fst
                    by contradiction /* impossible chain */
                  next
                    case d_0_snd
                    by solve( (#vr.3, 0) ~~> (#vk.2, 0) )
                  qed
                qed
              qed
            next
              case c_xor_case_2
              by solve( !KU( ~k ) @ #vk.4 )
            next
              case c_xor_case_3
              solve( !KU( (~kâŠ•r0) ) @ #vk.4 )
                case c_xor
                by solve( !KU( ~k ) @ #vk.5 )
              next
                case coerce
                solve( !KD( (~kâŠ•r0) ) â–¶â‚€ #vk.2 )
                  case acceptreader
                  by solve( (#vl, 0) ~~> (#vk.2, 0) )
                next
                  case initiatereader
                  by contradiction /* impossible chain */
                next
                  case tag1
                  solve( (#vl, 0) ~~> (#vk.2, 0) )
                    case d_0_fst
                    by contradiction /* impossible chain */
                  next
                    case d_0_snd
                    by solve( (#vr.3, 0) ~~> (#vk.2, 0) )
                  qed
                qed
              qed
            next
              case coerce
              solve( !KD( (~kâŠ•r0âŠ•h((~kâŠ•~r1âŠ•r0))) ) â–¶â‚€ #vk.1 )
                case acceptreader
                by solve( (#vl, 0) ~~> (#vk.1, 0) )
              next
                case initiatereader
                by contradiction /* impossible chain */
              next
                case tag1
                solve( (#vl, 0) ~~> (#vk.1, 0) )
                  case d_0_fst
                  by contradiction /* impossible chain */
                next
                  case d_0_snd
                  by solve( (#vr.3, 0) ~~> (#vk.1, 0) )
                qed
              qed
            qed
          next
            case tag1
            solve( splitEqs(3) )
              case split_case_1
              solve( !KU( h((~kâŠ•~r0âŠ•~r1)) ) @ #vk.2 )
                case c_h
                solve( !KU( (~kâŠ•~r0âŠ•~r1) ) @ #vk.3 )
                  case c_xor_case_1
                  by contradiction /* cyclic */
                next
                  case c_xor_case_2
                  by solve( !KU( ~k ) @ #vk.5 )
                next
                  case c_xor_case_3
                  by contradiction /* cyclic */
                next
                  case coerce
                  solve( !KD( (~kâŠ•~r0âŠ•~r1) ) â–¶â‚€ #vk.2 )
                    case acceptreader
                    by solve( (#vl.1, 0) ~~> (#vk.2, 0) )
                  next
                    case initiatereader
                    by contradiction /* impossible chain */
                  next
                    case tag1
                    solve( (#vl.1, 0) ~~> (#vk.2, 0) )
                      case d_0_fst
                      by contradiction /* impossible chain */
                    next
                      case d_0_snd
                      by solve( (#vr.5, 0) ~~> (#vk.2, 0) )
                    qed
                  qed
                qed
              next
                case tag1
                solve( splitEqs(5) )
                  case split
                  by contradiction /* cyclic */
                qed
              qed
            next
              case split_case_2
              solve( !KU( (~k.1âŠ•~r1.1) ) @ #vk.1 )
                case c_xor
                by solve( !KU( ~k.1 ) @ #vk.4 )
              next
                case coerce
                solve( !KD( (~k.1âŠ•~r1.1) ) â–¶â‚€ #vk.1 )
                  case acceptreader
                  by solve( (#vl.1, 0) ~~> (#vk.1, 0) )
                next
                  case initiatereader
                  by contradiction /* impossible chain */
                next
                  case tag1
                  solve( (#vl.1, 0) ~~> (#vk.1, 0) )
                    case d_0_fst
                    by contradiction /* impossible chain */
                  next
                    case d_0_snd
                    by solve( (#vr.6, 0) ~~> (#vk.1, 0) )
                  qed
                qed
              qed
            next
              case split_case_3
              solve( !KU( (xâŠ•~r1.1) ) @ #vk.1 )
                case c_xor
                solve( !KU( (xâŠ•h((~kâŠ•~r1âŠ•xâŠ•~r1.1))) ) @ #vk.2 )
                  case c_xor
                  solve( !KU( h((~kâŠ•~r1âŠ•xâŠ•~r1.1)) ) @ #vk.5 )
                    case c_h
                    solve( !KU( (~kâŠ•~r1âŠ•xâŠ•~r1.1) ) @ #vk.6 )
                      case c_xor_case_1
                      solve( !KU( (~kâŠ•~r1âŠ•~r1.1) ) @ #vk.7 )
                        case c_xor_case_1
                        by contradiction /* cyclic */
                      next
                        case c_xor_case_2
                        by solve( !KU( ~k ) @ #vk.9 )
                      next
                        case c_xor_case_3
                        by contradiction /* cyclic */
                      next
                        case coerce
                        solve( !KD( (~kâŠ•~r1âŠ•~r1.1) ) â–¶â‚€ #vk.5 )
                          case acceptreader
                          by solve( (#vl.1, 0) ~~> (#vk.5, 0) )
                        next
                          case initiatereader
                          by contradiction /* impossible chain */
                        next
                          case tag1
                          solve( (#vl.1, 0) ~~> (#vk.5, 0) )
                            case d_0_fst
                            by contradiction /* impossible chain */
                          next
                            case d_0_snd
                            by solve( (#vr.5, 0) ~~> (#vk.5, 0) )
                          qed
                        qed
                      qed
                    next
                      case c_xor_case_2
                      by contradiction /* cyclic */
                    next
                      case c_xor_case_3
                      solve( !KU( (~kâŠ•~r1.1) ) @ #vk.7 )
                        case c_xor
                        by contradiction /* cyclic */
                      next
                        case coerce
                        solve( !KD( (~kâŠ•~r1.1) ) â–¶â‚€ #vk.5 )
                          case acceptreader
                          by solve( (#vl.1, 0) ~~> (#vk.5, 0) )
                        next
                          case initiatereader
                          by contradiction /* impossible chain */
                        next
                          case tag1
                          solve( (#vl.1, 0) ~~> (#vk.5, 0) )
                            case d_0_fst
                            by contradiction /* impossible chain */
                          next
                            case d_0_snd
                            by solve( (#vr.5, 0) ~~> (#vk.5, 0) )
                          qed
                        qed
                      qed
                    next
                      case c_xor_case_4
                      by solve( !KU( ~k ) @ #vk.8 )
                    next
                      case c_xor_case_5
                      solve( !KU( (~r1âŠ•~r1.1) ) @ #vk.7 )
                        case c_xor
                        by contradiction /* cyclic */
                      next
                        case coerce
                        solve( !KD( (~r1âŠ•~r1.1) ) â–¶â‚€ #vk.5 )
                          case acceptreader
                          by solve( (#vl.1, 0) ~~> (#vk.5, 0) )
                        next
                          case initiatereader
                          by contradiction /* impossible chain */
                        next
                          case tag1
                          solve( (#vl.1, 0) ~~> (#vk.5, 0) )
                            case d_0_fst
                            by contradiction /* impossible chain */
                          next
                            case d_0_snd
                            by solve( (#vr.5, 0) ~~> (#vk.5, 0) )
                          qed
                        qed
                      qed
                    next
                      case c_xor_case_6
                      by contradiction /* cyclic */
                    next
                      case c_xor_case_7
                      by contradiction /* cyclic */
                    next
                      case coerce
                      solve( !KD( (~kâŠ•~r1âŠ•xâŠ•~r1.1) ) â–¶â‚€ #vk.4 )
                        case acceptreader
                        by solve( (#vl.1, 0) ~~> (#vk.4, 0) )
                      next
                        case initiatereader
                        by contradiction /* impossible chain */
                      next
                        case tag1
                        solve( (#vl.1, 0) ~~> (#vk.4, 0) )
                          case d_0_fst
                          by contradiction /* impossible chain */
                        next
                          case d_0_snd
                          by solve( (#vr.5, 0) ~~> (#vk.4, 0) )
                        qed
                      qed
                    qed
                  next
                    case tag1
                    solve( splitEqs(5) )
                      case split_case_1
                      by contradiction /* cyclic */
                    next
                      case split_case_2
                      by contradiction /* cyclic */
                    next
                      case split_case_3
                      solve( !KU( (~r1âŠ•~r1.1) ) @ #vk.6 )
                        case c_xor
                        by contradiction /* cyclic */
                      next
                        case coerce
                        solve( !KD( (~r1âŠ•~r1.1) ) â–¶â‚€ #vk.4 )
                          case acceptreader
                          by solve( (#vl.2, 0) ~~> (#vk.4, 0) )
                        next
                          case initiatereader
                          by contradiction /* impossible chain */
                        next
                          case tag1
                          solve( (#vl.2, 0) ~~> (#vk.4, 0) )
                            case d_0_fst
                            by contradiction /* impossible chain */
                          next
                            case d_0_snd
                            by solve( (#vr.7, 0) ~~> (#vk.4, 0) )
                          qed
                        qed
                      qed
                    next
                      case split_case_4
                      solve( !KU( (~kâŠ•~r1âŠ•~k.1âŠ•~r1.1) ) @ #vk.6 )
                        case c_xor_case_1
                        by solve( !KU( ~k.1 ) @ #vk.8 )
                      next
                        case c_xor_case_2
                        by contradiction /* cyclic */
                      next
                        case c_xor_case_3
                        solve( !KU( (~kâŠ•~r1.1) ) @ #vk.7 )
                          case c_xor
                          by contradiction /* cyclic */
                        next
                          case coerce
                          solve( !KD( (~kâŠ•~r1.1) ) â–¶â‚€ #vk.5 )
                            case acceptreader
                            by solve( (#vl.2, 0) ~~> (#vk.5, 0) )
                          next
                            case initiatereader
                            by contradiction /* impossible chain */
                          next
                            case tag1
                            solve( (#vl.2, 0) ~~> (#vk.5, 0) )
                              case d_0_fst
                              by contradiction /* impossible chain */
                            next
                              case d_0_snd
                              by solve( (#vr.8, 0) ~~> (#vk.5, 0) )
                            qed
                          qed
                        qed
                      next
                        case c_xor_case_4
                        by solve( !KU( ~k ) @ #vk.8 )
                      next
                        case c_xor_case_5
                        solve( !KU( (~r1âŠ•~r1.1) ) @ #vk.7 )
                          case c_xor
                          by contradiction /* cyclic */
                        next
                          case coerce
                          solve( !KD( (~r1âŠ•~r1.1) ) â–¶â‚€ #vk.5 )
                            case acceptreader
                            by solve( (#vl.2, 0) ~~> (#vk.5, 0) )
                          next
                            case initiatereader
                            by contradiction /* impossible chain */
                          next
                            case tag1
                            solve( (#vl.2, 0) ~~> (#vk.5, 0) )
                              case d_0_fst
                              by contradiction /* impossible chain */
                            next
                              case d_0_snd
                              by solve( (#vr.8, 0) ~~> (#vk.5, 0) )
                            qed
                          qed
                        qed
