theory LAK06_UK1

begin

// Function signature and definition of the equational theory E

builtins: multiset, xor
functions: fst/1, h/1, pair/2, snd/1
equations: fst(<x.1, x.2>) = x.1, snd(<x.1, x.2>) = x.2

rule (modulo E) setup:
   [ Fr( ~k1 ), Fr( ~k2 ) ]
  --[ OnlyOnce( 'setup' ), Create( ~k1 ), Create( ~k2 ) ]->
   [
   TagRun( ~k1, 'learning' ), TagRun( ~k2, 'learning' ),
   TagRun( diff(~k1, ~k2), 'guessing' )
   ]

rule (modulo E) initiatereader:
   [ ReaderRun( ~k, phase ), Fr( ~r0 ) ]
  --[ Phase( phase ) ]->
   [ ReaderState1( ~k, ~r0, phase ), Out( ~r0 ) ]

rule (modulo E) tag1:
   [ TagRun( ~k, phase ), Fr( ~r1 ), In( r0 ) ]
  --[ Running( <'R', 'T', ~k, r0, ~r1> ), Phase( phase ) ]->
   [ TagState1( ~k, ~r1, r0, phase ), Out( <~r1, h((~kвЉ•~r1вЉ•r0))> ) ]

rule (modulo E) acceptreader:
   [ ReaderState1( ~k, ~r0, phase ), In( <r1, h((~kвЉ•~r0вЉ•r1))> ) ]
  --[
  Commit( <'R', 'T', ~k, ~r0, r1> ), Running( <'T', 'R', ~k, ~r0, r1> ),
  Phase( phase )
  ]->
   [ Out( h((~kвЉ•~r0вЉ•h((~kвЉ•~r0вЉ•r1)))) ) ]

rule (modulo E) accepttag:
   [ TagState1( ~k, ~r1, r0, phase ), In( h((~kвЉ•r0вЉ•h((~kвЉ•~r1вЉ•r0)))) ) ]
  --[ Commit( <'T', 'R', ~k, r0, ~r1> ), FinTag( ), Phase( phase ) ]->
   [ ]

restriction onylOnce [right]:
  "в€Ђ x #i1 #i2.
    ((OnlyOnce( x ) @ #i1) в€§ (OnlyOnce( x ) @ #i2)) в‡’ (#i1 = #i2)"
  // safety formula

restriction onylOnce [left]:
  "в€Ђ x #i1 #i2.
    ((OnlyOnce( x ) @ #i1) в€§ (OnlyOnce( x ) @ #i2)) в‡’ (#i1 = #i2)"
  // safety formula

lemma executable [right]:
  exists-trace
  "(в€ѓ #i. FinTag( ) @ #i) в€§
   (в€Ђ x #i1 #i2.
     ((OnlyOnce( x ) @ #i1) в€§ (OnlyOnce( x ) @ #i2)) в‡’ (#i1 = #i2))"
/*
guarded formula characterizing all satisfying traces:
"(в€ѓ #i. (FinTag( ) @ #i)) в€§
 (в€Ђ x #i1 #i2. (OnlyOnce( x ) @ #i1) в€§ (OnlyOnce( x ) @ #i2) в‡’ #i1 = #i2)"
*/
simplify
solve( TagState1( ~k, ~r1, r0, phase ) в–¶в‚Ђ #i )
  case tag1_case_1
  solve( splitEqs(0) )
    case split_case_1
    by solve( !KU( ~k ) @ #vk.1 )
  next
    case split_case_2
    solve( !KU( h((~kвЉ•h((~kвЉ•~r1)))) ) @ #vk )
      case c_h
      solve( !KU( (~kвЉ•h((~kвЉ•~r1))) ) @ #vk.2 )
        case c_xor
        by solve( !KU( ~k ) @ #vk.4 )
      next
        case coerce
        solve( !KD( (~kвЉ•h((~kвЉ•~r1))) ) в–¶в‚Ђ #vk.1 )
          case acceptreader
